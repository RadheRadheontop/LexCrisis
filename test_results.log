    def step(self, action: ActionRequest) -> StepResponse:
        """Process one agent action and return observation + reward.
    
        Reward computation:
            1. Snapshot the grader score before processing the action (old_score).
            2. Execute the action handler, which updates findings.
            3. Re-run the grader to get the new score (new_score).
            4. reward = (new_score - old_score) + step_penalty
               where step_penalty is negative if the handler reported an error.
        """
        if self._done:
            return StepResponse(
                observation=self._make_observation("Episode is already complete. Call reset() to start a new episode."),
                reward=0.0,
                done=True,
                score=self._score,
                info={"episode_id": self._episode_id, "score": self._score}
            )
    
        self._step_count += 1
        self._last_read_text = None  # Clear per-step
